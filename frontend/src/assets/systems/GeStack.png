<svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e0f2f1;stop-opacity:1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Círculo externo -->
  <circle cx="100" cy="100" r="90" stroke="url(#logoGradient)" stroke-width="4" fill="none" opacity="0.6" filter="url(#glow)"/>
  
  <!-- Círculo intermediário -->
  <circle cx="100" cy="100" r="75" stroke="url(#logoGradient)" stroke-width="3" fill="none" opacity="0.4"/>
  
  <!-- Letra G estilizada -->
  <path d="M 100 40 
           C 130 40, 150 60, 150 90
           L 150 110
           L 120 110
           L 120 90
           L 130 90
           C 130 75, 120 60, 100 60
           C 75 60, 60 75, 60 100
           C 60 125, 75 140, 100 140
           C 115 140, 125 135, 130 125
           L 150 135
           C 145 150, 125 160, 100 160
           C 65 160, 40 135, 40 100
           C 40 65, 65 40, 100 40 Z" 
        fill="url(#logoGradient)" filter="url(#glow)"/>
  
  <!-- Detalhe interno -->
  <circle cx="100" cy="100" r="15" fill="url(#logoGradient)" opacity="0.8"/>
  
  <!-- Pontos decorativos -->
  <circle cx="100" cy="30" r="4" fill="url(#logoGradient)" filter="url(#glow)"/>
  <circle cx="170" cy="100" r="4" fill="url(#logoGradient)" filter="url(#glow)"/>
  <circle cx="100" cy="170" r="4" fill="url(#logoGradient)" filter="url(#glow)"/>
  <circle cx="30" cy="100" r="4" fill="url(#logoGradient)" filter="url(#glow)"/>
</svg>
