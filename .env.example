# FRONTEND — copie para frontend/.env (embutido no build)
# Produção VPS: deixe VITE_API_URL vazio (o app usa /api relativo ao mesmo domínio).
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
VITE_GELEADS_AUDIT_SLUG=geleads

# BACKEND — copie para backend/.env (use SUPABASE_*, não VITE_*)
# Deve coincidir com upstream em deploy/nginx-geleads.conf (padrão VPS: 3031)
SERVER_PORT=3031
NODE_ENV=production
# Banco Neon com site_solar_bosque e tabela unificada `all_leads`.
# Se omitido, o backend usa NEON_GETEAMS_DATABASE_URL.
NEON_LEADS_DATABASE_URL=postgresql://usuario:senha@host.neon.tech/geleads
NEON_GETEAMS_DATABASE_URL=postgresql://usuario:senha@host.neon.tech/geteams
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
