# Copie este arquivo para .env e preencha os valores (nunca commite .env com dados reais).

# --- Supabase (obrigatório para login, registro e dados) ---
# Obtenha em: https://supabase.com/dashboard → seu projeto → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Neon GeTeams (aba Corporativo do perfil) ---
# Usado apenas pelo servidor (server/index.mjs). Nunca expor no frontend.
# Connection string do banco Neon do projeto GêTeams (tabela collaborators, chave corporate_email).
# Para a aba Corporativo funcionar: 1) preencha aqui e no .env  2) suba o servidor com npm run server OU npm run dev:all
NEON_GETEAMS_DATABASE_URL=

# --- Servidor da API (opcional) ---
# Porta do servidor Express (padrão 3001). O Vite faz proxy de /api para http://localhost:3001
# SERVER_PORT=3001

# --- Frontend (opcional) ---
# URL base da API. Deixe vazio ou comentado para produção (Hostinger): o fetch usa /api/corporate-profile no mesmo domínio.
# Em dev o Vite faz proxy de /api para localhost:3001. Não defina como http://localhost:3001 no build de produção.
# VITE_GEAPPS_API_URL=
