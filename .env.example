# Copie para .env na raiz (não commitar credenciais reais).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API Node (npm run server) — opcional.
# NEON_GETEAMS_DATABASE_URL=...

# Só no servidor: usada para confirmar que existe linha em public.profiles antes de devolver
# dados corporativos em GET /api/corporate-profile-by-email (ignora RLS ao verificar outro e-mail).
# Nunca use esta chave no frontend nem em VITE_*.
# SUPABASE_SERVICE_ROLE_KEY=
